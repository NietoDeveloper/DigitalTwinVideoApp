{
  "name": "dt-video-landing-backend",
  "version": "1.0.0",
  "description": "General backend API for Digital Twin Video App - Software DT",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio",
    "prisma:migrate": "npx prisma migrate dev",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up"
  },
  "keywords": [
    "digital-twin",
    "video-app",
    "mern",
    "typescript",
    "software-dt"
  ],
  "author": "NietoDeveloper",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}